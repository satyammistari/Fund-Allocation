# Blockchain Configuration
PRIVATE_KEY=your_wallet_private_key_here
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com/
POLYGON_RPC_URL=https://polygon-rpc.com/
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Contract Addresses (will be filled after deployment)
VITE_CONTRACT_PROJECT_REGISTRY=
VITE_CONTRACT_APPROVAL_WORKFLOW=
VITE_CONTRACT_FUND_MANAGEMENT=
VITE_CONTRACT_DOCUMENT_VERIFICATION=

# IPFS Configuration (Pinata)
VITE_PINATA_API_KEY=your_pinata_api_key
VITE_PINATA_SECRET_KEY=your_pinata_secret_key
VITE_PINATA_JWT=your_pinata_jwt_token

# Network Configuration
VITE_NETWORK_NAME=mumbai
VITE_CHAIN_ID=80001
VITE_BLOCK_EXPLORER=https://mumbai.polygonscan.com

# API Keys
ETHERSCAN_API_KEY=your_polygonscan_api_key
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# Application Configuration
VITE_APP_NAME=Municipal Fund Tracker
VITE_MAX_FILE_SIZE=10485760
VITE_SUPPORTED_FILE_TYPES=.pdf,.jpg,.jpeg,.png,.doc,.docx

# Feature Flags
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DARK_MODE=true
